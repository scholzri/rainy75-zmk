config BOARD_RAINY75
	select SOC_TLSR9518
	select HAS_POWEROFF

# Note: the ISO/ANSI physical layout is NOT a Kconfig option. A Kconfig symbol
# can't drive it, because the keymap + matrix transform are devicetree, which is
# preprocessed before Kconfig runs. ANSI is selected via the devicetree
# preprocessor symbol RAINY75_ANSI — build with `./build.sh --ansi` (which passes
# -DDTS_EXTRA_CPPFLAGS=-DRAINY75_ANSI). See rainy75.keymap / rainy75.dts.
