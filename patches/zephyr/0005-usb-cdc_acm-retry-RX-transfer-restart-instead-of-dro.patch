From e95d5783a2aec4e16c5de1dc576f56d154672a51 Mon Sep 17 00:00:00 2001
From: Micheal Waltz <micheal@ecliptik.com>
Date: Thu, 23 Jul 2026 19:11:23 -0700
Subject: [PATCH] usb: cdc_acm: retry RX transfer restart instead of dropping
 it
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The RX resubmit in cdc_acm_read_cb() and the restart on CONFIGURED
ignored usb_transfer()'s return value.  The transfer layer can
transiently refuse a submission — e.g. a canceled transfer on the same
endpoint has not yet drained its deferred completion, which is routine
during enumeration churn (repeated reset/reconfigure cycles).  The
dropped restart left bulk OUT reception permanently dead on a device
the host considered fully configured and healthy.

Reproduced on hardware (Telink B91 composite CDC-ACM+HID) with forced
usb_disable()/usb_enable() cycling racing SMP traffic: RX chain dead
within 20 cycles, no recovery until re-enumeration happened to land
with no undrained cancel in flight.

Schedule a short retry (10 ms, system workqueue) when the restart
fails, until it lands or the port is deconfigured.

Signed-off-by: Micheal Waltz <micheal@ecliptik.com>
---
 subsys/usb/device/class/cdc_acm.c | 32 +++++++++++++++++++++++++++++--
 1 file changed, 30 insertions(+), 2 deletions(-)

diff --git a/subsys/usb/device/class/cdc_acm.c b/subsys/usb/device/class/cdc_acm.c
index 469215e6a..66c098f93 100644
--- a/subsys/usb/device/class/cdc_acm.c
+++ b/subsys/usb/device/class/cdc_acm.c
@@ -105,6 +105,7 @@ struct cdc_acm_dev_data_t {
 #if defined(CONFIG_CDC_ACM_DTE_RATE_CALLBACK_SUPPORT)
 	cdc_dte_rate_callback_t rate_cb;
 #endif
+	struct k_work_delayable rx_retry_work;
 	struct k_work_delayable tx_work;
 	/* Tx ready status. Signals when */
 	bool tx_ready;
@@ -328,8 +329,33 @@ static void cdc_acm_read_cb(uint8_t ep, int size, void *priv)
 
 done:
 	if (dev_data->configured) {
-		usb_transfer(ep, dev_data->rx_buf, sizeof(dev_data->rx_buf),
-			     USB_TRANS_READ, cdc_acm_read_cb, dev_data);
+		if (usb_transfer(ep, dev_data->rx_buf,
+				 sizeof(dev_data->rx_buf), USB_TRANS_READ,
+				 cdc_acm_read_cb, dev_data) < 0) {
+			/* The transfer layer can transiently refuse (e.g. a
+			 * canceled transfer on this endpoint has not drained
+			 * its deferred completion yet, common during
+			 * enumeration churn).  Dropping the restart here
+			 * leaves RX permanently dead with the device looking
+			 * configured and healthy; retry until it lands or
+			 * the port is deconfigured.
+			 */
+			LOG_WRN("RX transfer restart busy, retrying");
+			k_work_reschedule(&dev_data->rx_retry_work, K_MSEC(10));
+		}
+	}
+}
+
+static void cdc_acm_rx_retry_handler(struct k_work *work)
+{
+	struct k_work_delayable *dwork = k_work_delayable_from_work(work);
+	struct cdc_acm_dev_data_t *dev_data =
+		CONTAINER_OF(dwork, struct cdc_acm_dev_data_t, rx_retry_work);
+	struct usb_cfg_data *cfg = (void *)dev_data->common.dev->config;
+
+	if (dev_data->configured) {
+		cdc_acm_read_cb(cfg->endpoint[ACM_OUT_EP_IDX].ep_addr, 0,
+				dev_data);
 	}
 }
 
@@ -504,6 +530,8 @@ static int cdc_acm_init(const struct device *dev)
 		dev, dev_data, dev->config, &cdc_acm_data_devlist);
 
 	k_work_init(&dev_data->cb_work, cdc_acm_irq_callback_work_handler);
+	k_work_init_delayable(&dev_data->rx_retry_work,
+			      cdc_acm_rx_retry_handler);
 	k_work_init_delayable(&dev_data->tx_work, tx_work_handler);
 
 	return ret;
-- 
2.53.0

